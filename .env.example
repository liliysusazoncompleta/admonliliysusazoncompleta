# ── Servidor ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de Datos ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lili_sazon
DB_USER=postgres
DB_PASSWORD=your_password

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ── Email (Nodemailer) ─────────────────────────────────────────────────
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=465
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_password

# ── WhatsApp ───────────────────────────────────────────────────────────
# URL de la API de WhatsApp (dejar en blanco para modo mock/desarrollo)
# Ejemplos:
#   - https://api.twilio.com/2010-04-01/Accounts/{ACCOUNT_SID}/Messages.json
#   - https://graph.instagram.com/v18.0/your_phone_number_id/messages
WHATSAPP_API_URL=https://api.example.com/send

# Token/autenticación para la API de WhatsApp
WHATSAPP_TOKEN=your_whatsapp_api_token

# ── Cliente ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
